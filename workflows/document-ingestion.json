      "id": "5e23758a-c74f-44e3-8fbb-c7b44d59b024",
      "name": "Wait",
      "webhookId": "52d506d8-4c22-4500-a4a1-c4e208ae038e"
    },
    {
      "parameters": {
        "jsCode": "// Get plain text from Extract from File node\nconst text = $input.item.json.text || '';\n\nconst doc_name = $('Edit Fields').first().json.doc_name;\nconst doc_url = $('Edit Fields').first().json.doc_url;\n\n// Chunking settings\nconst chunkSize = 500;\nconst overlap = 50;\n\n// Split into words\nconst words = text.split(/\\s+/).filter(w => w.length > 0);\n\nconst chunks = [];\nlet i = 0;\n\nwhile (i < words.length) {\n  const chunkWords = words.slice(i, i + chunkSize);\n  const chunkText = chunkWords.join(' ');\n\n  if (chunkText.trim().length > 20) {\n    chunks.push({\n      json: {\n        pageContent: chunkText,\n        doc_name: doc_name,\n        doc_url: doc_url\n      }\n    });\n  }\n\n  i += chunkSize - overlap;\n}\n\nreturn chunks;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
        112
      ],
      "id": "cf7e0dee-a928-4db7-8bdb-ec34d350f494",
      "name": "Split Text into Chunks"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a document labeling assistant.\n\nRead the following text chunk and return a short \nsection label of 3-6 words that describes what \nthis chunk is about.\n\nDocument type: {{ $('Edit Fields').item.json.doc_name }}\n\nText chunk:\n{{ $('Loop Over Items').item.json.pageContent }}\n\nReturn ONLY the label. No explanation, no \npunctuation, no extra words.",
        "hasOutputParser": true,
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        1312,
        -16
      ],
      "id": "86f351ef-0e7b-4455-925b-7dbd759009df",
      "name": "Basic LLM Chain"
    },
