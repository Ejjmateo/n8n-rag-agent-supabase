      ],
      "id": "f95c29d8-abe0-463c-a037-9f2bb3a80414",
      "name": "Default Data Loader"
    },
    {
      "parameters": {
        "jsCode": "// Get section from LLM node output\nconst section = $input.first().json.text.trim()\n  .replace(/['\".,!?]/g, '');\n\n// Get chunk content\nconst pageContent = $('Loop Over Items').first().json.pageContent || '';\n\n// Get document metadata\nconst doc_name = $('Edit Fields').first().json.doc_name;\nconst doc_url = $('Edit Fields').first().json.doc_url;\n\n// Skip empty chunks\nif (!pageContent || pageContent.trim().length < 20) {\n  return [];\n}\n\nreturn [{\n  json: {\n    pageContent: pageContent,\n      metadata: {\n      doc_name: doc_name,\n      section: section,\n      doc_url: doc_url\n    }\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
