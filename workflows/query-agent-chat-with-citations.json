    {
      "parameters": {
        "jsCode": "const reply =\n  $json.reply ||\n  $json.output ||\n  $json.text ||\n  $json.message?.content ||\n  \"\";\n\n// \ud83d\udd25 Pull from earlier node\nconst chatId = $('Clean Input').first().json.chat_id;\n\nfunction cleanForTelegram(text) {\n  return String(text)\n    .replace(/[_*[\\]()~`>#+=|{}.!-]/g, \"\\\\$&\")\n    .slice(0, 4000);\n}\n\nreturn {\n  json: {\n    chat_id: chatId,\n    reply: cleanForTelegram(reply)\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
